{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "STM32 Debug (ST-Link)",
            "type": "cortex-debug",
            "request": "launch",
            "servertype": "openocd",
            "executable": "${workspaceFolder}/MDK-ARM/remote/remote.axf",
            "configFiles": [
                "interface/stlink.cfg",
                "target/stm32f1x.cfg"
            ],
            "runToEntryPoint": "main",
            "showDevDebugOutput": "raw"
        },
        {
            "name": "STM32 Debug (J-Link)",
            "type": "cortex-debug",
            "request": "launch",
            "servertype": "jlink",
            "executable": "${workspaceFolder}/MDK-ARM/remote/remote.axf",
            "device": "STM32F103C8",
            "interface": "SWD",
            "runToEntryPoint": "main",
            "showDevDebugOutput": "raw"
        }
    ]
}
